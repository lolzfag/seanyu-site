# Keystatic CMS — GitHub OAuth credentials
# -----------------------------------------
# These are generated automatically by the Keystatic setup wizard the first
# time you visit /keystatic (locally). After the wizard completes, they'll
# appear in a new `.env` file. Copy them into Vercel → Project Settings →
# Environment Variables to enable /keystatic on the live site.
#
# Docs: https://keystatic.com/docs/github-mode

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Any long random string. Generated by the wizard; or create yourself with:
#   openssl rand -base64 32
KEYSTATIC_SECRET=
